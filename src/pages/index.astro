---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class:list={[
        "grid gap-8 py-14 sm:grid-cols-[1fr_auto] sm:items-end sm:py-20",
        "border-b border-border/80",
      ]}
    >
      <div>
        <h1
          data-i18n="site.title"
          class="max-w-3xl font-display text-5xl leading-[0.98] font-light text-foreground sm:text-7xl"
        >
          Koshkin blog
        </h1>
        <p
          data-i18n="site.desc"
          class="mt-6 max-w-2xl text-2xl leading-snug text-foreground-muted sm:text-3xl"
        >
          Bits and pieces of writing.
        </p>
      </div>
      <div class="flex flex-col gap-5 sm:items-end">
        <a
          target="_blank"
          href="/rss.xml"
          class="inline-flex items-center gap-2 rounded-full border border-border bg-surface/80 px-4 py-2 font-ui text-sm text-foreground-muted shadow-(--shadow-soft) transition hover:border-accent/45 hover:text-accent"
          aria-label="rss feed"
          title="RSS Feed"
        >
          <IconRss
            width={18}
            height={18}
            class="stroke-current stroke-2 rtl:-rotate-90"
          />
          RSS
        </a>
        {
          SOCIALS.length > 0 && (
            <div class="flex flex-col gap-2 sm:items-end">
              <div
                data-i18n="home.links"
                class="font-ui text-xs tracking-[0.08em] text-foreground-muted uppercase"
              >
                Links
              </div>
              <Socials />
            </div>
          )
        }
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-14 pb-7",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="font-display text-4xl leading-tight font-light text-foreground">
            <span data-i18n="home.featured">Featured</span>
          </h2>
          <ul class="mt-6">
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-14 pb-7">
          <h2 class="font-display text-4xl leading-tight font-light text-foreground">
            <span data-i18n="home.recent">Recent Posts</span>
          </h2>
          <ul class="mt-6">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-10 text-center font-ui text-sm">
      <LinkButton
        href="/posts/"
        class="rounded-full border border-border bg-surface/75 px-5 py-2 text-foreground-muted shadow-(--shadow-soft) hover:border-accent/40"
      >
        <span data-i18n="home.allPosts">All Posts</span>
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
