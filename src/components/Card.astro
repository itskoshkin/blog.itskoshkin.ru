---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;
---

<li
  class="group my-5 rounded-sm border border-border bg-surface/85 p-5 shadow-(--shadow-soft) transition duration-300 hover:-translate-y-0.5 hover:border-accent/35 hover:bg-surface sm:p-6"
>
  <a
    href={getPath(id, filePath)}
    class:list={[
      "inline-block font-display text-2xl leading-tight font-light text-foreground transition-colors sm:text-3xl",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>
  </a>
  <Datetime {...props} class="mt-3" />
  <p class="mt-4 max-w-2xl text-foreground-muted">{description}</p>
</li>
