---
import IconHash from "@/assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "inline-flex items-center gap-1 rounded-full border border-border bg-surface/70 px-3 py-1 font-ui text-foreground-muted transition duration-200",
      "hover:-translate-y-0.5 hover:border-accent/50 hover:text-accent hover:shadow-(--shadow-soft)",
      "focus-visible:border-accent focus-visible:text-accent",
      { "text-xs": size === "sm" },
      { "text-sm": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-80",
        { "size-4": size === "lg" },
        { "size-3.5": size === "sm" },
      ]}
    />
    {tagName}
  </a>
</li>
