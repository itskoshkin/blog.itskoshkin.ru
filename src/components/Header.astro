---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconLanguage from "@/assets/icons/IconLanguage.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  data-i18n="skip.toContent"
  class="absolute start-16 -top-full z-50 rounded-sm border border-border bg-surface px-3 py-2 font-ui text-sm text-accent shadow-(--shadow-soft) backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-5 sm:py-7",
      "border-b border-border/80",
      "relative w-full bg-background",
      "flex items-center justify-between",
    ]}
  >
    <a
      href="/"
      data-i18n="site.title"
      class="py-1 font-display text-2xl leading-none font-light whitespace-nowrap text-foreground transition-colors hover:text-accent sm:text-3xl"
    >
      {SITE.title}
    </a>
    <nav
      id="nav-menu"
      class="flex flex-col items-end font-ui text-[0.78rem] font-medium tracking-[0.08em] uppercase sm:ms-2 sm:flex-row sm:justify-end sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline rounded-full border border-border bg-surface p-2 text-foreground shadow-(--shadow-soft) sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "absolute top-14 right-0 z-50 mt-3 grid w-56 grid-cols-3 place-content-center gap-1 rounded-sm border border-border bg-surface p-3 shadow-(--shadow-soft)",
          "[&>li>a]:relative [&>li>a]:block [&>li>a]:rounded-sm [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:text-foreground-muted [&>li>a]:transition-colors [&>li>a]:hover:text-accent sm:[&>li>a]:px-0 sm:[&>li>a]:py-1",
          "hidden",
          "sm:static sm:mt-0 sm:flex sm:w-auto sm:grid-cols-none sm:gap-x-6 sm:gap-y-0 sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none",
        ]}
      >
        <li class="col-span-3">
          <a
            href="/posts"
            data-i18n="nav.posts"
            class:list={{ "active-nav": isActive("/posts") }}
          >
            Posts
          </a>
        </li>
        <li class="col-span-3">
          <a
            href="/tags"
            data-i18n="nav.tags"
            class:list={{ "active-nav": isActive("/tags") }}
          >
            Tags
          </a>
        </li>
        <li class="col-span-3">
          <a
            href="/about"
            data-i18n="nav.about"
            class:list={{ "active-nav": isActive("/about") }}
          >
            About
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-3">
              <LinkButton
                href="/archives"
                class:list={[
                  "focus-outline flex justify-center rounded-sm p-3 text-foreground-muted transition-colors hover:text-accent sm:p-1",
                  {
                    "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                  },
                ]}
                title="Archives"
                data-i18n-title="nav.archives"
                data-i18n-aria-label="nav.archives"
                aria-label="archives"
              >
                <IconArchive class="hidden sm:inline-block" />
                <span class="sm:sr-only" data-i18n="nav.archives">
                  Archives
                </span>
              </LinkButton>
            </li>
          )
        }
        <li class="col-span-1 flex items-center justify-center">
          <LinkButton
            href="/search"
            class:list={[
              "focus-outline flex p-3 sm:p-1",
              "rounded-sm text-foreground-muted transition-colors hover:text-accent",
              { "text-accent [&>svg]:stroke-accent": isActive("/search") },
            ]}
            title="Search"
            data-i18n-title="nav.search"
            data-i18n-aria-label="nav.search"
            aria-label="search"
          >
            <IconSearch />
            <span class="sr-only" data-i18n="nav.search">Search</span>
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="col-span-1 flex items-center justify-center">
              <button
                id="theme-btn"
                class="focus-outline relative size-12 rounded-sm p-4 text-foreground-muted transition-colors hover:text-accent sm:size-8"
                title="Toggles light & dark"
                data-i18n-title="theme.toggle"
                data-i18n-aria-label="theme.toggle"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
        <li class="relative col-span-1 flex items-center justify-center">
          <button
            id="language-btn"
            class="focus-outline flex items-center justify-center rounded-sm p-3 text-foreground-muted transition-colors hover:text-accent sm:p-1"
            title="Language"
            data-i18n-title="nav.language"
            data-i18n-aria-label="nav.language"
            aria-label="Language"
            aria-expanded="false"
            aria-haspopup="listbox"
            aria-controls="language-menu"
          >
            <IconLanguage aria-hidden="true" class="scale-110" />
            <span class="sr-only" data-i18n="nav.language">Language</span>
          </button>
          <div
            id="language-menu"
            class="absolute top-12 right-0 z-50 hidden min-w-36 rounded-sm border border-border bg-surface p-2 text-left tracking-normal normal-case shadow-(--shadow-soft) sm:top-9"
            role="listbox"
          >
            <button
              type="button"
              class="block w-full rounded-sm px-3 py-2 text-left text-foreground-muted transition-colors hover:text-accent"
              data-language-option="en"
              data-i18n="language.english"
              role="option"
            >
              English
            </button>
            <button
              type="button"
              class="block w-full rounded-sm px-3 py-2 text-left text-foreground-muted transition-colors hover:text-accent"
              data-language-option="ru"
              data-i18n="language.russian"
              role="option"
            >
              Русский
            </button>
          </div>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
